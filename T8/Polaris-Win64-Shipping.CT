    <CheatEntry>
      <ID>383</ID>
      <Description>"Change Game Speed"</Description>
      <Options moHideChildren="1"/>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript>[ENABLE]

aobscanmodule(changeSlowMoSpeed,Polaris-Win64-Shipping.exe,CC CC CC CC CC 89 51 08 C3 CC)
alloc(newmem,$1000,changeSlowMoSpeed)

label(code)
label(return)

label(speedVar)
registersymbol(speedVar)

newmem:

  mov edx,[speedVar]

code:
  mov [rcx+08],edx

  ret 
  int 3
  jmp return

speedVar:
dd 64

changeSlowMoSpeed+05:
  jmp newmem
return:
registersymbol(changeSlowMoSpeed)

[DISABLE]

changeSlowMoSpeed+05:
  db 89 51 08 C3 CC

unregistersymbol(changeSlowMoSpeed)
dealloc(newmem)
unregistersymbol(speedVar)

