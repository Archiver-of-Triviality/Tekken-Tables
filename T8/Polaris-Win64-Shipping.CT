    <CheatEntry>
      <ID>1337027999</ID>
      <Description>"Inject Frame History"</Description>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript>[ENABLE]
{$lua}
local function injectEmbeddedDLL(dllName)
  local tblFile = findTableFile(dllName)
  if not tblFile then
    return false
  end

  local tempPath = os.getenv("TEMP") .. "\\" .. dllName
  local file = io.open(tempPath, "wb")
  if not file then
    return false
  end

  local stream = tblFile.Stream
  stream.Position = 0
  local size = stream.Size
  local bytes = stream.Read(size)

  local chars = {}
  for i = 1, #bytes do
    chars[i] = string.char(bytes[i])
  end
  local str = table.concat(chars)

  file:write(str)
  file:close()

  local success = injectDLL(tempPath)
  return success, tempPath
end

if not frameHistoryInjected then
  local success, path = injectEmbeddedDLL("frameHistory.dll")
  if success then
    frameHistoryInjected = true
    frameHistoryTempPath = path
  end
end
{$asm}

[DISABLE]
{$lua}
if frameHistoryInjected and frameHistoryTempPath then
  os.remove(frameHistoryTempPath)
  frameHistoryInjected = false
  frameHistoryTempPath = nil
end
{$asm}

</AssemblerScript>
    </CheatEntry>
    <CheatEntry>
      <ID>1337030246</ID>
      <Description>"Info"</Description>
      <Options moAlwaysHideChildren="1" moActivateChildrenAsWell="1" moDeactivateChildrenAsWell="1"/>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript>[ENABLE]

// 80 BB 46 09 00 00 00 old
// 80 BB 66 09 00 00 00 old
// 80 BB C0 09 00 00 00 old
// 80 BB D8 09 00 00 00 74 09 C7 47 2C 06 00 00 00 old
// 80 BB F8 09 00 00 00 74 09 C7 47 2C 06 00 00 00 old
