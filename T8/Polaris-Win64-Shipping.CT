    <CheatEntry>
      <ID>1337027999</ID>
      <Description>"Inject Frame History"</Description>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript>[ENABLE]
{$lua}
local function injectEmbeddedDLL(dllName)
  local tblFile = findTableFile(dllName)
  if not tblFile then
    return false
  end

  local tempPath = os.getenv("TEMP") .. "\\" .. dllName
  local file = io.open(tempPath, "wb")
  if not file then
    return false
  end

  local stream = tblFile.Stream
  stream.Position = 0
  local size = stream.Size
  local bytes = stream.Read(size)

  local chars = {}
  for i = 1, #bytes do
    chars[i] = string.char(bytes[i])
  end
  local str = table.concat(chars)

  file:write(str)
  file:close()

  local success = injectDLL(tempPath)
  return success, tempPath
end

if not frameHistoryInjected then
  local success, path = injectEmbeddedDLL("frameHistory.dll")
  if success then
    frameHistoryInjected = true
    frameHistoryTempPath = path
  end
end
{$asm}

[DISABLE]
{$lua}
if frameHistoryInjected and frameHistoryTempPath then
  os.remove(frameHistoryTempPath)
  frameHistoryInjected = false
  frameHistoryTempPath = nil
end
{$asm}

</AssemblerScript>
    </CheatEntry>
    <CheatEntry>
      <ID>1337030520</ID>
      <Description>"Info"</Description>
      <Options moAlwaysHideChildren="1" moActivateChildrenAsWell="1" moDeactivateChildrenAsWell="1"/>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript>[ENABLE]

// 80 BB 46 09 00 00 00 old
// 80 BB 66 09 00 00 00 old
// 80 BB C0 09 00 00 00 old
// 80 BB D8 09 00 00 00 74 09 C7 47 2C 06 00 00 00 old
// 80 BB F8 09 00 00 00 74 09 C7 47 2C 06 00 00 00 old
// 80 BB FC 09 00 00 00 74 09 C7 47 2C 06 00 00 00 new
// 80 BB 00 0A 00 00 00 74 09 C7 47 2C 06 00 00 00
// 80 BB 70 0A 00 00 00 74 09 C7 47 2C 06 00 00 00
// 80 BB EC 0B 00 00 00 74 09 C7 47 2C 06 00 00 00

// == Animation info and frame data ==

aobscanmodule(pcFinder,Polaris-Win64-Shipping.exe,80 BB EC 0B 00 00 00 74 09) // should be unique
alloc(newmem,$1000,pcFinder)

label(code)
label(return)

label(pcFinderPTR)
registersymbol(pcFinderPTR)


newmem:
  cmp [rbx+00000004],(int)0
  jne code
  mov [pcFinderPTR],rbx // 92D offset = Power Crush Value

code:
  cmp byte ptr [rbx+00000BEC],00
  jmp return
  //cmp byte ptr [rbx+00000A70],00
  //jmp return


pcFinderPTR:
dd 0


pcFinder:
  jmp newmem
  nop 2
return:
registersymbol(pcFinder)

[DISABLE]

pcFinder:
  db 80 BB EC 0B 00 00 00

unregistersymbol(pcFinder)
dealloc(newmem)
unregistersymbol(pcFinderPTR)


