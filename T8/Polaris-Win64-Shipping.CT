      <CheatEntries>
        <CheatEntry>
          <ID>1337030576</ID>
          <Description>"Display Move Data"</Description>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>{$lua}
[ENABLE]
if syntaxcheck then return end

-- === Clean up any existing form ===
if TextOverlayForm then TextOverlayForm.destroy() TextOverlayForm = nil end
if t then t.destroy() t = nil end

-- === Create the form ===
TextOverlayForm = createForm(false)
local f = TextOverlayForm
f.BorderStyle = 'bsNone'
f.Color = 0x101010 -- Dark background
f.AlphaBlend = true
f.AlphaBlendValue = 220 -- Semi-transparent
f.FormStyle = 'fsSystemStayOnTop'
f.ShowInTaskBar = 'stNever'
f.Left = 60
f.Top = 270
f.Width = 215
f.Height = 307
f.Caption = ""

-- === Make draggable ===
local dragging, dx, dy = false, 0, 0
f.OnMouseDown = function(_, _, x, y)
  dragging, dx, dy = true, x, y
end
f.OnMouseMove = function(_, x, y)
  if dragging then
    f.Left = f.Left + (x - dx)
    f.Top = f.Top + (y - dy)
  end
end
f.OnMouseUp = function() dragging = false end

-- === Helper to create text labels ===
local function createTextLabel(parent, top, caption)
  local label = createLabel(parent)
  label.Font.Name = 'Segoe UI'
  label.Font.Size = 16
  label.Font.Color = 0xFFFFFF
  label.Font.Quality = 'fqClearType'
  label.AutoSize = false
  label.Alignment = 'taLeftJustify'
  label.Caption = caption
  label.Left = 10
  label.Top = top
  label.Width = parent.Width - 20
  label.Height = 31
  return label
end

-- === Create text labels ===
local animTimerLabel      = createTextLabel(f, 10, "")
local recvLabel           = createTextLabel(f, 42, "recv: ")
local totalRecoveryLabel  = createTextLabel(f, 74, "tot: ")
local delayLabel          = createTextLabel(f, 106, "delay: ")
local jsLabel             = createTextLabel(f, 138, "js: ")
local csLabel             = createTextLabel(f, 170, "cs: 0~")
local pcLabel             = createTextLabel(f, 202, "pc: 0~")
local dmgLabel            = createTextLabel(f, 234, "dmg: ")
local heatLabel           = createTextLabel(f, 266, "heat: 0 / 900")

-- === State tracking variables ===
local wasCrouching = false
local crouchingFrameStart = 0
local lastCrouchingFrame = 0
local csDisplayDelay = 3000
local csResetAt = 0

local wasPC = false
local pcFrameStart = 0
local lastPCFrame = 0
local prevTotalRecovery = 0
local pcResetAt = 0

local pcFinderPtrAddr = getAddressSafe('pcFinderPTR')
local csPtrAddr = getAddressSafe('csPTR')

local function readPtr(addr)
  if not addr or addr == 0 then return 0 end
  if targetIs64Bit() then
    return readQword(addr) or 0
  end
  return readInteger(addr) or 0
end

local function setCaptionIfChanged(label, text)
  if label.Caption ~= text then
    label.Caption = text
  end
end

local function rol64(v, n)
  n = n &amp; 63
  if n == 0 then
    return v &amp; 0xFFFFFFFFFFFFFFFF
  end
  return ((v &lt;&lt; n) | (v &gt;&gt; (64 - n))) &amp; 0xFFFFFFFFFFFFFFFF
end

local function calcEncodedChecksum(enc, key)
  local chk = 0
  local low28 = enc &amp; 0x0FFFFFFF
  local shift = 0

  while shift &lt; 0x1C do
    chk = (chk ~ low28 ~ rol64(key, shift + 4)) &amp; 0xF
    low28 = low28 &gt;&gt; 4
    shift = shift + 4
  end

  if chk == 0 then
    chk = 1
  end

  return ((enc &amp; 0x0FFFFFFF) | (chk &lt;&lt; 28)) &amp; 0xFFFFFFFF
end

local function decodeProtectedInt(addr)
  local enc = readInteger(addr)
  if enc == nil then
    return nil
  end

  local key = readQword(addr + 0x8)
  if key == nil then
    key = 0
  end

  enc = enc &amp; 0xFFFFFFFF
  key = key &amp; 0xFFFFFFFFFFFFFFFF

  if calcEncodedChecksum(enc, key) ~= enc then
    return nil
  end

  local t = enc ~ 0x1D
  local mixed = (t ~ (rol64(key, t &amp; 0x1F) &amp; 0xFFFFFFE0)) &amp; 0x0FFFFFFF
  return mixed
end

-- === Timer ===
t = createTimer(f)
t.Interval = 1
t.OnTimer = function()
  if not pcFinderPtrAddr then pcFinderPtrAddr = getAddressSafe('pcFinderPTR') end
  if not csPtrAddr then csPtrAddr = getAddressSafe('csPTR') end

  local nowMs = getTickCount()
  local pcFinderBase = readPtr(pcFinderPtrAddr)
  local animInfoBase = readPtr(pcFinderBase + 0x3E0)

  local animTimer = readInteger(pcFinderBase + 0x390) or 0
  local valuePCFinder = readInteger(pcFinderBase + 0x5E0) or 0 -- valuePCFinder = total recovery frames
  local valueLAF = readInteger(animInfoBase + 0x15C) or 0
  local valueJS = readInteger(animInfoBase + 0x124) or 0
  local jsEnd = readInteger(animInfoBase + 0x128) or 0
  local delay = readInteger(pcFinderBase + 0x2788) or 0
  local cs = (csPtrAddr and (readInteger(csPtrAddr) or 0)) or 0
  local pc = readBytes(pcFinderBase + 0xBEC+0x31, 1, false) or 0
  local dmg = readInteger(pcFinderBase + 0x504) or 0
  local heatScaled = decodeProtectedInt(pcFinderBase + 0x2470)
  local transition = readInteger(animInfoBase + 0xCC) or 0

  local result = valuePCFinder - valueLAF
  if result &gt;= 0x80000000 then result = result - 0x100000000 end

  setCaptionIfChanged(animTimerLabel, string.format("%d", animTimer))
  if transition == 32770 then
    setCaptionIfChanged(recvLabel, string.format("recv: %d FC", math.abs(result)))
  else
    setCaptionIfChanged(recvLabel, string.format("recv: %d", math.abs(result)))
  end
  setCaptionIfChanged(totalRecoveryLabel, string.format("tot: %d", valuePCFinder))

  local combinedValue = valuePCFinder + delay
  setCaptionIfChanged(delayLabel, string.format("delay: %d-%d", delay, combinedValue))
  setCaptionIfChanged(jsLabel, string.format("js: %d~%d", valueJS, jsEnd))
  setCaptionIfChanged(dmgLabel, string.format("dmg: %d", dmg))
  if heatScaled then
    local heatFrames = math.floor((heatScaled + 50) / 100)
    setCaptionIfChanged(heatLabel, string.format("heat: %d / 900", heatFrames))
  else
    setCaptionIfChanged(heatLabel, "heat: ? / 900")
  end

  -- === CS Tracking ===
  if cs == 1 then
    if not wasCrouching then
      crouchingFrameStart = animTimer
      wasCrouching = true
      csResetAt = 0
    end
    lastCrouchingFrame = animTimer
  elseif wasCrouching then
    wasCrouching = false
    csResetAt = nowMs + csDisplayDelay
  end

  if not wasCrouching and csResetAt &gt; 0 and nowMs &gt;= csResetAt then
    crouchingFrameStart = 0
    lastCrouchingFrame = 0
    csResetAt = 0
  end

  if lastCrouchingFrame &gt; 0 then
    setCaptionIfChanged(csLabel, string.format("cs: %d~%d", crouchingFrameStart, lastCrouchingFrame))
  else
    setCaptionIfChanged(csLabel, "cs: 0~0")
  end

  -- === PC Tracking ===
  if valuePCFinder ~= prevTotalRecovery then
    pcFrameStart = 0
    lastPCFrame = 0
    wasPC = false
    pcResetAt = 0
  end

  if pc == 1 then
    if not wasPC then
      pcFrameStart = animTimer
      wasPC = true
      pcResetAt = 0
    end
    lastPCFrame = animTimer
  elseif wasPC then
    wasPC = false
    pcResetAt = nowMs + csDisplayDelay
  end

  if not wasPC and pcResetAt &gt; 0 and nowMs &gt;= pcResetAt then
    pcFrameStart = 0
    lastPCFrame = 0
    pcResetAt = 0
  end

  if lastPCFrame &gt; 0 then
    setCaptionIfChanged(pcLabel, string.format("pc: %d~%d", pcFrameStart, lastPCFrame))
  else
    setCaptionIfChanged(pcLabel, "pc: 0~0")
  end

  prevTotalRecovery = valuePCFinder
end

-- === Show form ===
f.show()

[DISABLE]
if syntaxcheck then return end
if TextOverlayForm then TextOverlayForm.destroy() TextOverlayForm = nil end
if t then t.destroy() t = nil end

</AssemblerScript>
        </CheatEntry>
        <CheatEntry>
          <ID>1337030577</ID>
          <Description>"Crouch Status Finder"</Description>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>[ENABLE]

// 88 87 14 08 00 00
// 88 86 14 08 00 00
// 88 0C 10 48 8B 4C 24 20
// 88 0C 02 4C 8B 44 24 20 41 83 B8 14 15 00 00 00 7F 14 41 83 B8 1C 15 00 00 00 75 0A 41 C6 85 2D 08 00 00 00 EB 08

aobscanmodule(csFinder,Polaris-Win64-Shipping.exe,88 0C 02 4C 8B 44 24 20)
alloc(newmem,$1000,csFinder)

label(code)
label(return)

label(csPTR)
registersymbol(csPTR)

newmem:
  //cmp [rdi+000007AC],(int)0
  //cmp [rsi+000007AC],(int)0
  cmp [rdx+7AC],(int)0
  jg code
  mov [csPTR],cl

code:
  mov [rdx+rax],cl
  mov r8,[rsp+20]
  jmp return

csPTR:
dd 0

csFinder:
  jmp newmem
  nop 3
return:
registersymbol(csFinder)

[DISABLE]

csFinder:
  db 88 0C 02 4C 8B 44 24 20

unregistersymbol(csFinder)
dealloc(newmem)
unregistersymbol(csPTR)
</AssemblerScript>
